{
  "name": "Certus",
  "short_name": "Certus",
  "description": "Documentação MCMV simplificada",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#1A3C34",
  "theme_color": "#1A3C34",
  "icons": [
    { "src": "/assets/images/icon.png", "sizes": "192x192", "type": "image/png" },
    { "src": "/assets/images/icon.png", "sizes": "512x512", "type": "image/png" }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "application/pdf"]
        }
      ]
    }
  }
}
