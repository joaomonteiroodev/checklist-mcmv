{
  "expo": {
    "name": "Certus",
    "slug": "checklist-mcmv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "checklistmcmv",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A3C34",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "manifest": {
        "name": "Certus",
        "short_name": "Certus",
        "theme_color": "#1A3C34",
        "background_color": "#1A3C34",
        "icons": [
          {
            "src": "./assets/images/icon.png",
            "sizes": "1024x1024",
            "type": "image/png"
          }
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A3C34",
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}